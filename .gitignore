# ==============================================================================
# .gitignore — DAX Copilot Context-Aware
# ==============================================================================

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ── Ambiente Virtual ────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Variáveis de Ambiente (SEGURANÇA) ──────────────────────────────────
.env

# ── IDE / Editor ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── uv ──────────────────────────────────────────────────────────────────
.python-version

# ── Memória / Bancos de Dados (Agno Sessions) ───────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Streamlit ───────────────────────────────────────────────────────────
.streamlit/

# ── Dados (NUNCA ENVIAR PARA GITHUB) ──────────────────────────────────
data/
*.csv
*.xlsx
*.xls

# ── Documentação de Desenvolvimento ──────────────────────────────────
walkthrough.md
task.md
implementation_plan.md
